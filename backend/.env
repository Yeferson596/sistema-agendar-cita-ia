# Base de datos: para desarrollo local usa SQLite.
# Para producci n o Docker PostgreSQL, cambia esta URL a tu servidor PostgreSQL.
DATABASE_URL=sqlite:///./mediflow.db

# JWT para autenticaci n de tokens.
JWT_SECRET=cambia-esto-por-una-cadena-muy-segura
JWT_ALGORITHM=HS256
JWT_EXP_HOURS=168

# Or genes permitidos para CORS en el frontend.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://0.0.0.0:3000

# Selecci n de proveedor de IA.
AI_PROVIDER=auto

# Claves de API para los proveedores de IA.
ROQ_API_KEY=
ROQ_MODEL=llama-3.3-70b-versatile
OPENAI_API_KEY=
OPENAI_MODEL=gpt-3.5-turbo

# Google OAuth (opcional, solo si usas login con Google).
GOOGLE_CLIENT_ID=

# Correos de administrador separados por comas.
ADMIN_EMAILS=admin@tudominio.com

# Configuraci n de agenda.
APPOINTMENT_DURATION_MINUTES=30
CLINIC_OPEN_HOUR=8
CLINIC_CLOSE_HOUR=18
SLOT_STEP_MINUTES=30
