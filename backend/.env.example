# Sin PostgreSQL local: SQLite (un solo archivo en backend/)
DATABASE_URL=sqlite:///./mediflow.db
# Con Docker/Postgres:
# DATABASE_URL=postgresql+psycopg://mediflow:mediflow@localhost:5432/mediflow
JWT_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio
# Añade TODAS las URLs desde donde se accederá al frontend (importante para Windows)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://0.0.0.0:3000
AI_PROVIDER=auto
GEMINI_MODEL=gemini-2.0-flash
GEMINI_API_KEY=
OPENAI_MODEL=gpt-3.5-turbo
OPENAI_API_KEY=
GOOGLE_CLIENT_ID=
ADMIN_EMAILS=admin@example.com
